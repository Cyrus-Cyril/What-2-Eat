# --- 后端 Python 忽略项 ---
# 忽略虚拟环境文件夹
venv/
.venv/
**/venv/
**/.venv/

# 忽略 Python 运行产生的缓存文件
**/__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.egg-info/

# 忽略打包产物
dist/
build/

# 忽略本地环境变量配置文件（里面可能有你的 API Key）
.env

# 忽略运行时数据目录
data/

# --- 前端 Node.js 忽略项 ---
# 忽略前端依赖包（体积巨大，队友可以自己 npm install）
frontend/node_modules/

# 忽略打包后的产物
frontend/dist/
frontend/build/
frontend/.next/
frontend/.nuxt/
frontend/.output/

# 前端日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 前端环境变量
frontend/.env
frontend/.env.local
frontend/.env.*.local

# --- 系统与编辑器忽略项 ---
.DS_Store
.vscode/
.idea/