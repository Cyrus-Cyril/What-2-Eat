# Large language model (LLM) configuration
LLM_API_KEY=
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-turbo

# 如果要使用地图api获取餐馆数据，将这个改为false即可
USE_MOCK=true

# Database configuration
DB_USER=root
DB_PASSWORD=123456
DB_HOST=localhost
DB_PORT=3306
DB_NAME=what2eat
# 或者直接配置完整的 DB_URL
# DB_URL=mysql+aiomysql://root:123456@localhost:3306/what2eat

# 云redis连接
# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=name
REDIS_PASSWORD=password
REDIS_DB=0
